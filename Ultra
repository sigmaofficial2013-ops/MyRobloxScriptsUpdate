-- ============================================================
--  1. КОНФИГУРАЦИЯ (МЕНЯЙ ПОД СЕБЯ)
-- ============================================================
local Config = {
    AutoTreat = true,          -- Автолечение
    AutoCollect = true,        -- Автосбор наград
    InfiniteSanity = true,     -- Бесконечный рассудок
    ESP = true,                -- Подсветка пациентов и аномалий
    SpeedMultiplier = 50,      -- Ускорение всех процессов (1 = норма)
    TreatDelay = 0.05,         -- Задержка между действиями (сек)
    GUIKey = Enum.KeyCode.F5,  -- Клавиша открытия GUI
}

-- ============================================================
--  2. СЛУЖЕБНЫЕ ФУНКЦИИ (НЕ ТРОГАТЬ)
-- ============================================================
local Players = game:GetService("Players")
